# Cloudflare Pages — header rules (static, no build)
/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: SAMEORIGIN
  Referrer-Policy: strict-origin-when-cross-origin
  Content-Security-Policy: default-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self'; connect-src 'self' https://api.dfx.swiss https://dev.api.dfx.swiss; object-src 'none'; base-uri 'none'; frame-ancestors 'self'

# Image assets have stable names → cache aggressively
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Render-blocking → short max-age so repeat visits paint from cache, updates roll out within an hour
/platform.js
  Cache-Control: public, max-age=3600

# Same-origin scripts (incl. render-blocking js/lib/*-core.js) → short max-age so
# updates roll out within an hour instead of being pinned by an immutable cache
/js/*
  Cache-Control: public, max-age=3600
