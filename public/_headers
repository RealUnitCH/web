# Cloudflare Pages — header rules (static, no build)
/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: SAMEORIGIN
  Referrer-Policy: strict-origin-when-cross-origin
  Content-Security-Policy: default-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self'; connect-src 'self' https://api.dfx.swiss https://dev.api.dfx.swiss; object-src 'none'; base-uri 'none'; frame-ancestors 'self'

# Image assets have stable names → cache aggressively
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Same-origin scripts (incl. the render-blocking js/lib/*-core.js). We set 1h at
# the origin, but the realunit.app Cloudflare zone's "Browser Cache TTL" (4h)
# raises any shorter value, so the effective browser cache is ~4h; a longer value
# like the immutable /assets/* above is respected instead. The point is that these
# stay OFF the immutable cache so updates still roll out; if the zone ever switches
# to "Respect Existing Headers", the 1h here applies verbatim.
/platform.js
  Cache-Control: public, max-age=3600

/js/*
  Cache-Control: public, max-age=3600
